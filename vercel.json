{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/check-4d",
      "schedule": "0-15 11 * * 1,4"
    },
    {
      "path": "/api/cron/check-4d",
      "schedule": "45-59 10 * * 1,4"
    },
    {
      "path": "/api/cron/check-toto",
      "schedule": "45-59 10 * * 0,3,6"
    },
    {
      "path": "/api/cron/check-toto",
      "schedule": "0-15 11 * * 0,3,6"
    }
  ],
  "env": {
    "CRON_SECRET": "@cron-secret",
    "SUPABASE_URL": "@supabase-url",
    "SUPABASE_KEY": "@supabase-key"
  }
}
