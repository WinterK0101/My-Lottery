{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/check-4d",
      "schedule": "45 18 * * WED,SAT,SUN"
    },
    {
      "path": "/api/cron/check-toto",
      "schedule": "45 18 * * MON,THU"
    }
  ],
  "env": {
    "CRON_SECRET": "@cron-secret",
    "SUPABASE_URL": "@supabase-url",
    "SUPABASE_KEY": "@supabase-key"
  }
}
